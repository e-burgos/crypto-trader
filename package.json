{
  "name": "crypto-trader",
  "version": "1.0.0",
  "description": "Fullstack crypto trading platform",
  "private": true,
  "scripts": {
    "nx": "nx",
    "dev": "pnpm docker:infra && pnpm dev:api & pnpm dev:web",
    "dev:api": "pnpm nx serve api",
    "dev:web": "pnpm nx serve web",
    "build": "pnpm nx run-many --target=build --all",
    "build:api": "pnpm nx build api",
    "build:web": "pnpm nx build web",
    "test:all": "pnpm nx run-many --target=test --all --exclude=crypto-trader",
    "test:api": "pnpm nx test api",
    "test:web": "pnpm nx test web",
    "test:e2e": "pnpm nx run-many --target=e2e --all",
    "test:e2e:api": "pnpm nx e2e api-e2e",
    "test:e2e:web": "pnpm nx e2e web-e2e",
    "lint:all": "pnpm nx run-many --target=lint --all --exclude=crypto-trader",
    "lint:fix": "pnpm nx run-many --target=lint --all -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:push": "cd apps/api && npx prisma db push",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:migrate:deploy": "cd apps/api && npx prisma migrate deploy",
    "db:seed": "cd apps/api && npx prisma db seed",
    "db:studio": "cd apps/api && npx prisma studio",
    "db:generate": "pnpm exec prisma generate --schema=apps/api/prisma/schema.prisma",
    "docker:infra": "docker compose up -d postgres redis",
    "typecheck": "pnpm nx run-many --target=typecheck --all",
    "affected:build": "pnpm nx affected --target=build",
    "affected:test": "pnpm nx affected --target=test",
    "affected:lint": "pnpm nx affected --target=lint"
  },
