# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<dbname>?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="<generate-with: openssl rand -hex 64>"
JWT_REFRESH_SECRET="<generate-with: openssl rand -hex 64>"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Encryption ────────────────────────────────────────────────────────────────
# Must be exactly 32 characters for AES-256 encryption of Binance/LLM API keys
BINANCE_KEY_ENCRYPTION_KEY="<exactly-32-chars-secret-key-here>"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:4200"

# ── Binance API URLs ──────────────────────────────────────────────────────────
# Override Binance endpoints (useful for geo-restricted regions like US)
# Public data (klines, ticker) — no geo-restrictions:
BINANCE_PUBLIC_URL="https://data-api.binance.vision"
# Authenticated requests (orders, account) — may be geo-restricted:
BINANCE_BASE_URL="https://api.binance.com"

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used by Vite (apps/web). Must be VITE_API_URL — NOT VITE_API_BASE_URL
VITE_API_URL="http://localhost:3000/api"

# ── Embeddings (RAG / Orchestrator) ──────────────────────────────────────────
# Required for the multi-agent RAG pipeline. Provide ONE of the two options:
# Option A — Voyage AI (voyage-3, 1024 dims) — preferred
VOYAGE_API_KEY="<voyage-ai-api-key>"
# Option B — OpenAI key reused for embeddings (text-embedding-3-small, 1536 dims)
# OPENAI_PLATFORM_KEY="<openai-api-key>"
