generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────

enum UserRole {
  TRADER
  ADMIN
}

enum Asset {
  BTC
  ETH
}

enum QuoteCurrency {
  USDT
  USDC
}

enum TradingMode {
  LIVE
  SANDBOX
  TESTNET
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum TradeType {
  BUY
  SELL
}

enum Decision {
  BUY
  SELL
  HOLD
}

enum IntervalMode {
  AGENT
  CUSTOM
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ── Spec 28 — Multi-Agent RAG ────────────────────────────────────────────────

enum AgentId {
  platform      // NEXUS  — Experto en CryptoTrader
  operations    // FORGE  — Asistente de Operaciones
  market        // SIGMA  — Analista de Mercado
  blockchain    // CIPHER — Experto en Blockchain
  risk          // AEGIS  — Gestor de Riesgo
  orchestrator  // KRYPTO — Orquestador central
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}enum NotificationType {
  TRADE_EXECUTED
  STOP_LOSS_TRIGGERED
  TAKE_PROFIT_HIT
  AGENT_ERROR
  AGENT_STARTED
  AGENT_STOPPED
  AGENT_KILLED
}

enum LLMProvider {
  CLAUDE
  OPENAI
  GROQ
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum NewsApiProvider {
  CRYPTOPANIC
  NEWSDATA
}

// ── Models ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(TRADER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  binanceCredentials BinanceCredential[]
  llmCredentials     LLMCredential[]
  newsApiCredentials NewsApiCredential[]
  tradingConfigs    TradingConfig[]
  positions         Position[]
  trades            Trade[]
  agentDecisions    AgentDecision[]
  notifications     Notification[]
  adminActions      AdminAction[]      @relation("AdminActions")
  targetedActions   AdminAction[]      @relation("TargetedActions")
  chatSessions       ChatSession[]
  sandboxWallets    SandboxWallet[]
  newsConfig        NewsConfig?
  newsAnalyses      NewsAnalysis[]

  @@map("users")
}

model BinanceCredential {
  id              String   @id @default(cuid())
  userId          String
  isTestnet       Boolean  @default(false)
  apiKeyEncrypted String
  secretEncrypted String
  apiKeyIv        String
  secretIv        String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, isTestnet])
  @@map("binance_credentials")
}

model LLMCredential {
  id              String      @id @default(cuid())
  userId          String
  provider        LLMProvider
  apiKeyEncrypted String
  apiKeyIv        String
  selectedModel   String
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("llm_credentials")
}

model NewsApiCredential {
  id              String          @id @default(cuid())
  userId          String
  provider        NewsApiProvider
  apiKeyEncrypted String
  apiKeyIv        String
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("news_api_credentials")
}

model TradingConfig {
  id                     String        @id @default(cuid())
  userId                 String
  name                   String        @default("")
  asset                  Asset
  pair                   QuoteCurrency
  buyThreshold           Float         @default(70)
  sellThreshold          Float         @default(70)
  stopLossPct            Float         @default(0.03)
  takeProfitPct          Float         @default(0.05)
  /// Minimum profit % required for LLM-driven SELL to execute (default 0.3%)
  minProfitPct           Float         @default(0.003)
  maxTradePct            Float         @default(0.05)
  maxConcurrentPositions Int           @default(2)
  minIntervalMinutes     Int           @default(5)
  intervalMode           IntervalMode  @default(AGENT)
  orderPriceOffsetPct    Float         @default(0)
  mode                   TradingMode   @default(SANDBOX)
  isRunning              Boolean       @default(false)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]

  @@map("trading_configs")
}

model Position {
  id         String         @id @default(cuid())
  userId     String
  configId   String
  asset      Asset
  pair       QuoteCurrency
  mode       TradingMode
  entryPrice Float
  quantity   Float
  entryAt    DateTime       @default(now())
  exitPrice  Float?
  exitAt     DateTime?
  status     PositionStatus @default(OPEN)
  pnl        Float?
  fees       Float          @default(0)

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  config TradingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId, status])
  @@index([userId, asset, status])
  @@map("positions")
}

model Trade {
  id             String      @id @default(cuid())
  userId         String
  positionId     String
  type           TradeType
  price          Float
  quantity       Float
  fee            Float
  executedAt     DateTime    @default(now())
  mode           TradingMode
  binanceOrderId String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([userId, executedAt])
  @@index([userId, mode])
  @@map("trades")
}

model AgentDecision {
  id            String        @id @default(cuid())
  userId        String
  configId      String?
  configName    String?
  mode          TradingMode?
  asset         Asset
  pair          QuoteCurrency
  decision      Decision
  confidence    Float
  reasoning     String
  indicators    Json
  newsHeadlines Json
  waitMinutes   Int
  /// Orchestration metadata: { orchestrated: boolean, subAgentResults: SubAgentResult[] }
  metadata      Json?
  createdAt     DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("agent_decisions")
}

model NewsItem {
  id          String    @id @default(cuid())
  source      String
  headline    String
  url         String    @unique
  sentiment   Sentiment @default(NEUTRAL)
  publishedAt DateTime
  cachedAt    DateTime  @default(now())

  @@index([publishedAt])
  @@map("news_items")
}

/// User-level news fetching preferences
model NewsConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  intervalMinutes Int      @default(30)
  newsCount       Int      @default(40)
  enabledSources  String[] @default([])
  onlySummary     Boolean  @default(true)
  /// Whether the trading bot should include news analysis in its decisions
  botEnabled      Boolean  @default(true)
  /// Weight (0-100%) that news sentiment carries in the LLM trading decision
  newsWeight      Int      @default(15)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("news_configs")
}

/// Persisted news sentiment analysis (keyword-based + optional AI layer)
model NewsAnalysis {
  id               String    @id @default(cuid())
  userId           String
  analyzedAt       DateTime  @default(now())
  newsCount        Int
  positiveCount    Int
  negativeCount    Int
  neutralCount     Int
  score            Int
  overallSentiment String
  summary          String
  /// JSON array of {id,source,headline,sentiment,summary?,author?,publishedAt}
  headlines        Json

  // AI layer (null until user triggers AI analysis)
  aiAnalyzedAt       DateTime?
  aiProvider         String?
  aiModel            String?
  aiPositiveCount    Int?
  aiNegativeCount    Int?
  aiNeutralCount     Int?
  aiScore            Int?
  aiOverallSentiment String?
  aiSummary          String?
  /// JSON array of {id,sentiment,reasoning}
  aiHeadlines        Json?

  // Orchestration enrichment (Phase 28 — OrchestratorService.enrichNews)
  technicalRelevance  Float?
  ecosystemImpact     String?
  orchestratedTags    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, analyzedAt])
  @@map("news_analyses")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model AdminAction {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetUserId String?
  details      Json     @default("{}")
  createdAt    DateTime @default(now())

  admin  User  @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
  target User? @relation("TargetedActions", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@map("admin_actions")
}

/// Virtual wallet for SANDBOX paper trading.
/// Created automatically on first agent start with 10,000 units each quote currency.
/// Updated atomically after every BUY / SELL so balance is always consistent.
model SandboxWallet {
  id        String        @id @default(cuid())
  userId    String
  currency  QuoteCurrency
  balance   Float         @default(10000)
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@map("sandbox_wallets")
}

model ChatSession {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("New Chat")
  provider  LLMProvider
  model     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, createdAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  metadata  Json?

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ── Spec 28: Agent definitions (configurable by Admin) ───────────────────────

model AgentDefinition {
  id          AgentId  @id
  displayName String
  description String
  systemPrompt String  @db.Text
  skills      Json     // string[]
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  documents AgentDocument[]

  @@map("agent_definitions")
}

model AgentDocument {
  id          String         @id @default(cuid())
  agentId     AgentId
  title       String
  fileName    String
  mimeType    String
  sizeBytes   Int
  status      DocumentStatus @default(PENDING)
  errorMsg    String?
  uploadedAt  DateTime       @default(now())
  processedAt DateTime?
  uploadedBy  String

  agent  AgentDefinition      @relation(fields: [agentId], references: [id])
  chunks AgentDocumentChunk[]

  @@index([agentId, status])
  @@map("agent_documents")
}

model AgentDocumentChunk {
  id         String  @id @default(cuid())
  documentId String
  agentId    AgentId
  content    String  @db.Text
  chunkIndex Int
  /// Float[] stored as JSON — pgvector column added via raw migration
  embedding  Json

  document AgentDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([documentId])
  @@map("agent_document_chunks")
}
